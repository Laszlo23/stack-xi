# Base mainnet (client-safe — VITE_ prefix)
VITE_BASE_CHAIN_ID=8453
VITE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
VITE_SQUAD_NFT_ADDRESS=
# Required for onchain predictions — deploy PredictionPool.sol and set address
VITE_PREDICTION_POOL_ADDRESS=
# Bonding curve: 770 BCC start + 70 BCC per mint (18 decimals)
VITE_MINT_BASE_PRICE_BCC=770000000000000000000
VITE_MINT_PRICE_INCREMENT_BCC=70000000000000000000

# Legacy USDC display (swap only)
VITE_MINT_BASE_PRICE_USDC=770000
VITE_MINT_PRICE_INCREMENT_USDC=70000

# BCC culture token (Base mainnet)
VITE_BCC_TOKEN_ADDRESS=0xb890a5289f789f1346032ccc1847939e855fab07
VITE_DEXSCREENER_POOL_URL=https://dexscreener.com/base/0xbb1a4e26d908a8fdddcea5d634faaa47eb8959b78384af66fea0bf45732143fb
VITE_BCC_UNISWAP_POOL=
VITE_BCC_AERODROME_POOL=

# Base App (optional deeplink)
VITE_BASE_APP_ID=

# Server / deploy scripts ONLY — never expose via VITE_*
# Prefer Alchemy when available:
ALCHEMY_API_KEY=
BASE_RPC_URL=https://mainnet.base.org
# Or: BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BASE_DEPLOYER_PRIVATE_KEY=

# Swap — tier A: classic 0x dashboard key (https://0x.org)
ZEROX_API_KEY=

# Swap — tier B: project x402 payer wallet (~$0.01 USDC/quote on Base)
# Dedicated hot wallet with USDC — NOT your deployer key unless intentional
X402_SWAP_PAYER_PRIVATE_KEY=
# Optional CDP facilitator when Base dev API is configured
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Social links (profile missions)
VITE_X_TARGET_POST_URL=
VITE_FARCASTER_FOLLOW_URL=
VITE_COMMUNITY_X_URL=
VITE_COMMUNITY_TELEGRAM_URL=
VITE_PLACES_SITE_URL=
VITE_TWITTER_SITE=@buildingcultu3

# SEO — set to your production domain (no trailing slash)
VITE_SITE_URL=https://pepe.buildingcultureid.space
# Google Search Console HTML tag content (optional)
# VITE_GOOGLE_SITE_VERIFICATION=

# Dev: bypass kickoff close for post-match testing only
VITE_PREDICTION_WINDOW_ALWAYS_OPEN=false
# Legacy strict mode: only open in final 90 min before kickoff (off by default)
# VITE_PREDICTION_WINDOW_STRICT=true

# Optional Farcaster auto-post (Neynar)
NEYNAR_API_KEY=
NEYNAR_SIGNER_UUID=
# Server-only: optional shared secret for trusted server scripts (browser uses same-origin)
INTERNAL_API_SECRET=

VITE_STACKS_NETWORK=mainnet
VITE_PREDICTION_POOL_STACKS=
