# Base mainnet (client-safe — VITE_ prefix)
VITE_BASE_CHAIN_ID=8453
VITE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
VITE_SQUAD_NFT_ADDRESS=
# Required for onchain predictions — deploy PredictionPool.sol and set address
VITE_PREDICTION_POOL_ADDRESS=
# Sponsored predictions — deploy PredictionSponsor.sol (see deploy:sponsor)
VITE_PREDICTION_SPONSOR_ADDRESS=
VITE_SPONSORED_PREDICTION_STAKE_BCC=1000000000000000000000
VITE_SPONSORED_PREDICTION_MAX=77
# Treasury fund amount when running deploy:sponsor (default 77000 BCC)
# SPONSOR_FUND_BCC=77000
# Bonding curve: 770 BCC start + 70 BCC per mint (18 decimals)
VITE_MINT_BASE_PRICE_BCC=770000000000000000000
VITE_MINT_PRICE_INCREMENT_BCC=70000000000000000000

# Legacy USDC display (swap only)
VITE_MINT_BASE_PRICE_USDC=770000
VITE_MINT_PRICE_INCREMENT_USDC=70000

# BCC culture token (Base mainnet)
VITE_BCC_TOKEN_ADDRESS=0xb890a5289f789f1346032ccc1847939e855fab07
VITE_DEXSCREENER_POOL_URL=https://dexscreener.com/base/0xbb1a4e26d908a8fdddcea5d634faaa47eb8959b78384af66fea0bf45732143fb
VITE_BCC_UNISWAP_POOL=
VITE_BCC_AERODROME_POOL=

# Base App (optional deeplink)
VITE_BASE_APP_ID=

# Server / deploy scripts ONLY — never expose via VITE_*
# Prefer Alchemy when available:
ALCHEMY_API_KEY=
# Full Base RPC URL (optional — overrides constructed URL from ALCHEMY_API_KEY)
ALCHEMY_BASE_ENDPOINT=
# Public address of your Alchemy **local** CLI wallet (must match ALCHEMY_WALLET_KEY)
# Session wallet from `alchemy wallet connect --mode session` cannot sign on VPS.
ALCHEMY_PUBLIC_WALLET_ADDRESS=
BASE_RPC_URL=https://mainnet.base.org
# Or: BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BASE_DEPLOYER_PRIVATE_KEY=

# Swap — tier A: classic 0x dashboard key (https://0x.org)
ZEROX_API_KEY=

# Swap — tier B (no Coinbase verification): Alchemy local CLI wallet pays x402 (~$0.01 USDC/quote)
# Sync from CLI: bun run sync:alchemy-cli-wallet
# Or: alchemy wallet connect --mode local
ALCHEMY_WALLET_KEY=
ALCHEMY_WALLET_KEY_FILE=
# Fallback order if ALCHEMY_WALLET_KEY unset: X402_SWAP_PAYER_PRIVATE_KEY → PRIVATE_KEY
X402_SWAP_PAYER_PRIVATE_KEY=
# bun run setup:alchemy-swap-payer → fund payer with USDC on Base

# Swap — tier B (optional): CDP API key wallet (needs Coinbase portal verification)
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=
# CDP_WALLET_SECRET=
# bun run setup:cdp-swap-payer
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# Social links (profile missions)
VITE_X_TARGET_POST_URL=https://x.com/bihary41418/status/2073264209333277051
VITE_FARCASTER_TARGET_CAST_URL=https://farcaster.xyz/0xleonardo/0xaefdb41b
VITE_FARCASTER_FOLLOW_URL=https://farcaster.xyz/0xleonardo

# X OAuth (server-only — create app at https://developer.x.com)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_CALLBACK_URL=https://pepe.buildingcultureid.space/api/auth/x/callback
X_TARGET_TWEET_ID=2073264209333277051

# X posting — OAuth 1.0a user context for @0xleonardo (Luck Agent)
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Luck Agent — Pepe social voice (server-only)
LUCK_AGENT_ADMIN_SECRET=
LUCK_AGENT_STORAGE_PATH=/var/www/pepe-buildingculture/data/luck-agent.json
LUCK_AGENT_AUTO_SUPPORT=1
LUCK_AGENT_AUTO_ORIGINAL=0
LUCK_AGENT_PAUSED=0
LUCK_AGENT_COOLDOWN_MINUTES=45
LUCK_AGENT_CAP_QUOTE=2
LUCK_AGENT_CAP_REPLY=3
LUCK_AGENT_CAP_RETWEET=1
LUCK_AGENT_CAP_ORIGINAL=2
LUCK_AGENT_CAP_MATCHDAY=2
# Comma-separated extra handles (no @): vitalik, balajis
LUCK_AGENT_WATCHLIST=
LUCK_AGENT_SLACK_WEBHOOK=
# Optional LLM refine for drafts only
OPENAI_API_KEY=
LUCK_AGENT_LLM_ENABLED=0

# Social account link storage (server-only JSON on VPS)
SOCIAL_STORAGE_PATH=/var/www/pepe-buildingculture/data/social-links.json

# Farcaster mini-app domain verification (from https://farcaster.xyz/~/developers/new)
# Sign with your Farcaster custody wallet for pepe.buildingcultureid.space, then paste values here.
FARCASTER_ACCOUNT_ASSOCIATION_HEADER=
FARCASTER_ACCOUNT_ASSOCIATION_PAYLOAD=
FARCASTER_ACCOUNT_ASSOCIATION_SIGNATURE=
VITE_COMMUNITY_X_URL=
VITE_COMMUNITY_TELEGRAM_URL=
# Public bot username (no @) — set after running bun run setup:telegram
VITE_TELEGRAM_BOT_USERNAME=

# Telegram bot (server-only — from @BotFather)
TELEGRAM_BOT_TOKEN=

# WalletConnect + Privy (Telegram mini app wallet connect)
VITE_WALLETCONNECT_PROJECT_ID=
VITE_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# SEO — set to your production domain (no trailing slash)
VITE_SITE_URL=https://pepe.buildingcultureid.space
# Google Search Console HTML tag content (optional)
# VITE_GOOGLE_SITE_VERIFICATION=

# Dev: bypass kickoff close for post-match testing only
VITE_PREDICTION_WINDOW_ALWAYS_OPEN=false
# Legacy strict mode: only open in final 90 min before kickoff (off by default)
# VITE_PREDICTION_WINDOW_STRICT=true

# Optional Farcaster auto-post (Neynar)
NEYNAR_API_KEY=
NEYNAR_SIGNER_UUID=
# Server-only: optional shared secret for trusted server scripts (browser uses same-origin)
INTERNAL_API_SECRET=

VITE_STACKS_NETWORK=mainnet
VITE_PREDICTION_POOL_STACKS=
